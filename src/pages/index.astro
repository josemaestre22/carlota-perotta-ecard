---
import '../styles/global.css';

import { Image, Font } from 'astro:assets';
import ResponsiveCarla from '../components/ResponsiveCarla.astro';
import imagen1 from '../assets/imagenCarla1.png';
import imagen2 from '../assets/imagenCarla2.png';
import iconSnowflake from '../assets/Snowflake.svg';
import iconSparkle from '../assets/Sparkle.svg';
import iconStar from '../assets/Star.svg';
import logo from '../assets/Logo.svg';

import iconMail from '../assets/IconMail.svg';
import iconTikTok from '../assets/IconTikTok.svg';
import iconWhatsAppSocial from '../assets/IconWhatsApp.svg';
import iconInstagram from '../assets/IconInstagram.svg';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Carla Perrotta, Psicóloga Clínica. Terapia para ansiedad, duelo, dependencia emocional y abuso narcisista. Agenda tu sesión y empieza a sanar tu historia." />
		<meta name="generator" content={Astro.generator} />
		<title>Carla Perrotta | Psicóloga Clínica</title>
		<Font cssVariable="--font-playfair" preload/>
		<Font cssVariable="--font-dmsans" preload/>
		<Font cssVariable="--font-inter"/>
	</head>
	<body>
		<header class="bg-primary py-6.5 md:py-10 flex items-center justify-center px-4 top-0 z-50">
			<p class="font-dmsans font-bold text-white text-base md:text-[1.5625rem] tracking-[0.16rem] leading-5.25 uppercase text-center max-w-[17.5rem] md:max-w-none">
				Sanar también es entender tu historia.
			</p>
		</header>
		<main>
			<!-- Seccion 1: Presentacion -->
			<section class="relative bg-secondary overflow-hidden -mt-[0.58rem] pt-7 pb-13 flex flex-col items-center md:h-[51.875rem] md:pt-0 md:pb-0 md:block">
				<!-- Contenedor de escritorio centrado y proporcional -->
				<div class="md:relative md:w-[90rem] md:mx-auto md:h-full">
					
					<!-- Nombre (Capa de fondo en desktop) -->
					<h1 class="font-playfair font-normal text-white text-[5.25rem] md:text-[14.78rem] leading-[0.77] text-center z-10 relative px-4 md:absolute md:top-[3.07rem] md:left-[30.8125rem] md:text-left md:flex md:flex-col md:items-start md:px-0 md:w-auto">
						<span>Carla</span>
						<span>Perrotta</span>
					</h1>

					<!-- Imagen de Carla -->
					<div class="relative flex flex-col items-center z-20 -mt-12 md:absolute md:left-[4.25rem] md:top-[3.61rem] md:mt-0">
						<div class="w-[20.511rem] h-[26.209rem] md:w-[38.154rem] md:h-[48.753rem]">
							<Image src={imagen1} layout='constrained' loading="eager" fetchpriority="high" alt="Carla Perrotta" class="w-full h-full object-cover"/>
						</div>
						<!-- Badge Mobile (Oculto en desktop) -->
						<span class="bg-primary text-white font-dmsans font-bold py-[0.59rem] px-[1.98rem] rounded-full text-[0.99rem] tracking-[0.099rem] uppercase -mt-8 z-30 relative whitespace-nowrap md:hidden">
							Psicóloga clínica
						</span>
					</div>

					<!-- Bloque de Información Desktop -->
					<div class="mt-2 flex flex-col items-center text-center px-6 z-30 md:absolute md:left-[42.125rem] md:top-[29rem] md:items-start md:text-left md:px-0 md:mt-0">
						<!-- Badge Desktop -->
						<span class="hidden md:inline-flex bg-primary text-white font-dmsans font-bold py-3 px-[2.5rem] rounded-[5.625rem] text-[1.25rem] tracking-[0.125rem] md:[font-variation-settings:'opsz'_14] uppercase mb-[1.81rem] whitespace-nowrap">
							Psicóloga clínica
						</span>
						
						<h2 class="font-inter font-bold text-dark text-[1.466875rem] md:text-[1.5625rem] leading-[1.26] mb-5 md:mb-[1.6rem] max-w-[18.4375rem] md:max-w-[35.375rem]">
							Psicoanálisis + terapia <br class="md:hidden" /> cognitivo-conductual
						</h2>

						<div class="font-inter font-medium text-dark text-xl md:text-[1.5625rem] leading-[1.44] max-w-[20.8125rem] md:max-w-[41.5625rem]">
							<p>Especializada en:</p>
							<p class="md:whitespace-nowrap">
								<span class="block md:inline">Ansiedad | Vínculos afectivos |</span>
								<span class="block md:inline"> Abuso narcisista</span>
							</p>
							<p>Dependencia emocional | Duelo</p>
						</div>
					</div>
				</div>
			</section>
			<!-- Seccion 2: Cita con Fondo Naranja -->
			<section class="bg-primary pt-16 pb-12 md:pt-36 md:pb-33 px-6 flex flex-col items-center justify-center text-center text-white">
				<div class="max-w-[19.5rem] md:max-w-[55.75rem]">
					<h2 class="font-playfair text-[1.886rem] md:text-[5.397rem] leading-[0.94] mb-3 md:mb-9 ">
						La <span class="font-bold">terapia</span> no es para personas rotas, <br/>
						<span class="font-bold">es para valientes</span> que quieren entenderse.
					</h2>
					<p class="font-inter text-[1.13rem] md:text-[2.576rem] leading-[1.33] uppercase opacity-90">
						Porque entenderte es el primer <br class="hidden md:inline"/>paso para dejar de repetir lo que te lastima.
					</p>
				</div>
			</section>
			<!-- Seccion 3: Beneficios -->
			<section class="relative bg-secondary-light overflow-hidden flex flex-col items-center justify-center pb-26 md:py-0 md:h-[43.25rem]">
				<div class="md:relative md:w-[90rem] md:mx-auto md:h-full flex flex-col md:flex-none items-center justify-center">
					<!-- Imagen de Carla -->
					<div class="w-full md:w-auto flex justify-center md:justify-start md:absolute md:left-[-6.65rem] md:top-[-8.09rem] -mt-5 md:mt-0">
						<div class="w-[27.4125rem] h-[41.11875rem] md:w-[55.26rem] md:h-[82.89rem] relative">
							<Image src={imagen2} layout='constrained' quality={95} alt="Carla Perrotta" class="w-full h-full object-cover" />
						</div>
					</div>
					<!-- Bloque de Beneficios -->
					<div class="-mt-57 md:mt-0 flex flex-col items-center md:items-start gap-[1.51rem] md:gap-[2.125rem] px-6 md:px-0 md:w-[34.96rem] md:absolute md:left-[47.68rem] md:top-1/2 md:-translate-y-1/2 z-10">
						<div class="intersect-once intersect:motion-preset-slide-left motion-duration-2000  bg-primary rounded-[1.29rem] md:rounded-[1.81rem] px-[1.25rem] md:px-7 py-2.5 md:py-3 flex items-center gap-[1.2rem] md:gap-[1.68rem] max-w-[18.81rem] md:max-w-none w-full">
							<div class="w-8.5 h-8.5 md:w-[3.07rem] md:h-[2.91rem] shrink-0">
								<Image src={iconSnowflake} alt="" class="w-full h-full" />
							</div>
							<div class="text-white text-[1.11rem] md:text-[1.56rem] leading-[1.44] font-inter">
								<p class="font-bold">Sanar no es olvidar lo que pasó.</p>
								<p>Es dejar de vivir atrapado en ello.</p>
							</div>
						</div>
						<div class="intersect-once intersect:motion-preset-slide-left motion-duration-2100 bg-primary rounded-[1.29rem] md:rounded-[1.81rem] px-[1.25rem] md:px-7 py-2.5 md:py-3 flex items-center gap-[1.2rem] md:gap-[1.68rem] max-w-[18.81rem] md:max-w-none w-full">
							<div class="w-8.5 h-8.5 md:w-[2.71rem] md:h-[2.82rem] shrink-0">
								<Image src={iconSparkle} alt="" class="w-full h-full" />
							</div>
							<p class="text-white text-[1.11rem] md:text-[1.56rem] leading-[1.44] font-inter font-bold">
								Entender lo que sientes cambia la forma en que te relacionas.
							</p>
						</div>
						<div class="intersect-once intersect:motion-preset-slide-left motion-duration-2200 bg-primary rounded-[1.29rem] md:rounded-[1.81rem] px-[1.25rem] md:px-10 py-2.5 md:py-3 flex items-center gap-[1.2rem] md:gap-[1.68rem] max-w-[18.81rem] md:max-w-none w-full">
							<div class="w-8.5 h-8.5 md:w-[2.99rem] md:h-[3.23rem] shrink-0">
								<Image src={iconStar} alt="" class="w-full h-full" />
							</div>
							<p class="text-white text-[1.11rem] md:text-[1.56rem] leading-[1.44] font-inter font-bold">
								No todo lo que duele es <br class="hidden md:inline"/>debilidad. <span class="font-medium">A veces es historia no comprendida.</span>
							</p>
						</div>
					</div>
				</div>
			</section>
			<!-- Seccion 4: Agenda de Cita -->
			<section class="relative bg-primary flex flex-col md:flex-row items-center md:justify-center pb-0 md:h-[51.875rem]">
				<!-- logo Carla Perrotta-->
				<div class="absolute -top-[2.75rem] md:-top-[4.75rem] left-1/2 -translate-x-1/2 w-[4.87rem] h-[4.87rem] md:w-[8.77rem] md:h-[8.77rem] z-40">
					<Image src={logo} alt="Logo Carla Perrotta" class="w-full h-full object-contain" />
				</div>
				
				<!-- Bloque de Texto -->
				<div class="flex flex-col items-center md:items-start pt-26 md:-mt-37 md:ml-50 md:-mr-30 text-center md:text-left z-10 ">
					<p class="font-inter font-medium text-white text-[1.5rem] md:text-[2.576rem] leading-[1.17] uppercase mb-2 md:mb-2.5 max-w-[20rem] md:max-w-[35.3rem]">
						A veces no necesitas más tiempo…
					</p>
					<h2 class="font-playfair text-white text-[2.25rem] md:text-[3.537rem] leading-[1.05] mb-7 md:mb-[2.62rem] max-w-[22rem] md:max-w-[37rem]">
						necesitas un <br/ class="md:hidden"> espacio donde <span class="font-bold italic">entender</span> lo que te pasa y <span class="font-bold italic">empezar a transformarlo.</span>
					</h2>
					<a href="https://wa.me/584146491115?text=Hola%2C%20estoy%20interesado%2Fa%20en%20iniciar%20un%20proceso%20terap%C3%A9utico%20contigo.%20%C2%BFPodr%C3%ADas%20darme%20informaci%C3%B3n%2C%20por%20favor%3F" class="flex bg-secondary-accent hover:bg-white transition-all px-[2.02rem] py-3 md:px-[2.87rem] md:py-4.25 rounded-full shadow-lg">
						<span class="font-inter font-extrabold text-dark text-[0.71rem] md:text-[1rem] leading-normal tracking-[0.1rem] md:tracking-[0.14rem] uppercase">
							Agenda tu sesión vía WhatsApp
						</span>
					</a>
				</div>

				<!-- Imagen Lateral Corregida con Art Direction (Custom Component) -->
				<div class="w-full md:h-full md:w-auto mt-5 md:mt-0">
					<ResponsiveCarla 
						imgClass="w-full h-auto md:h-full "
					/>
				</div>
			</section>
			<!-- Seccion 5: Inhala y Exala con Sincronización Bio-Feedback -->
			<section id="breathing-section" class="bg-secondary-light py-20 md:py-30 px-6 flex flex-col items-center text-center">
				<div class="flex flex-col items-center gap-10 md:gap-11 max-w-[19.125rem] md:max-w-none">
					<h2 class="font-playfair text-primary text-[3rem] md:text-[4.5rem] leading-[0.94]">
						<span class="font-bold italic">Si en este momento,</span><br class="md:hidden"/>
						<span class="font-normal">no te <br class="hidden md:inline"/>sientes cómodo con <br/ class="md:hidden"> tu sentir</span>
					</h2>
					
					<div class="w-[18.31rem] h-[2.58rem] md:w-[28rem] md:h-[4rem] relative">
						<svg id="pulse-drawing-svg" class="w-full h-full opacity-100 transition-opacity duration-700" preserveAspectRatio="none" viewBox="0 0 315 44" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path id="pulse-drawing-path" d="M1.3 41.8H47.5C50.2 28.3 55.6 1.3 55.6 1.3L66.6 42.2H88.3L96.4 12L104.5 42.1H203.5C206.2 28.3 211.6 1.3 211.6 1.3L222.6 42.6H244.3L252.4 12.4L260.5 42.5H313.3" stroke="#FD9651" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>

					<button id="breathing-btn" class="group relative bg-primary px-[2.87rem] py-4.5 md:px-11 md:py-4.25 rounded-[6.45rem] cursor-pointer hover:shadow-xl active:scale-95 outline-none will-change-transform transition-transform duration-700 ease-out">
						<p id="breathing-text" class="font-inter font-extrabold text-white text-[1rem] md:text-[1rem] tracking-[0.14rem] md:tracking-[0.14rem] uppercase whitespace-nowrap transition-opacity duration-200" aria-live="polite">
							Inhala y exala.
						</p>
					</button>
				</div>
			</section>

		</main>

		<footer class="bg-secondary py-18 md:py-16 flex flex-col items-center gap-[1.2rem]">
			<div class="flex flex-col items-center text-dark">
				<p class="font-inter font-bold text-[1.55rem] md:text-[2rem] leading-[1.2] pb-1">
					Contacto
				</p>
				<p class="font-inter font-normal text-[1.45rem] md:text-[2rem] leading-[1.44] text-center">
					Carla Perrotta  | Psicólogo
				</p>
			</div>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-[2.02rem]">
				<a href="mailto:Carlaperrottacorro@gmail.com" class="w-[4.74rem] h-[4.74rem] transition-transform hover:scale-110">
					<Image src={iconMail} alt="Email" class="w-full h-full object-contain" />
				</a>
				<a href="https://tiktok.com/@psicarlaperrotta" target="_blank" rel="noopener noreferrer" class="w-[4.74rem] h-[4.74rem] transition-transform hover:scale-110">
					<Image src={iconTikTok} alt="TikTok" class="w-full h-full object-contain" />
				</a>
				<a href="https://wa.me/584146491115?text=Hola%2C%20estoy%20interesado%2Fa%20en%20iniciar%20un%20proceso%20terap%C3%A9utico%20contigo.%20%C2%BFPodr%C3%ADas%20darme%20informaci%C3%B3n%2C%20por%20favor%3F" target="_blank" rel="noopener noreferrer" class="w-[4.74rem] h-[4.74rem] transition-transform hover:scale-110">
					<Image src={iconWhatsAppSocial} alt="WhatsApp" class="w-full h-full object-contain" />
				</a>
				<a href="https://instagram.com/psicarlaperrotta" target="_blank" rel="noopener noreferrer" class="w-[4.74rem] h-[4.74rem] transition-transform hover:scale-110">
					<Image src={iconInstagram} alt="Instagram" class="w-full h-full object-contain" />
				</a>
			</div>
		</footer>

		<script>
			const btn = document.getElementById('breathing-btn');
			const text = document.getElementById('breathing-text');
			const path = document.getElementById('pulse-drawing-path') as unknown as SVGPathElement;
			
			let isAnimating = false;
			let rafId: number;
			let currentDistance = 0;
			let lastTimestamp = 0;
			let currentUIState = 'idle'; 
			let isChangingText = false;

			const baselineY = 41.8;
			const peakY = 1.3;
			const length = path.getTotalLength();

			path.style.strokeDasharray = `${length}`;
			path.style.strokeDashoffset = '0';

			function setUIState(newState: string) {
				if (!text || currentUIState === newState || isChangingText) return;
				
				isChangingText = true;
				currentUIState = newState;
				text.style.opacity = '0';
				
				setTimeout(() => {
					if (newState === 'inhale') text.innerText = 'Inhala...';
					else if (newState === 'exhale') text.innerText = 'Exala...';
					else text.innerText = 'Inhala y exala.';
					
					text.style.opacity = '1';
					setTimeout(() => { isChangingText = false; }, 200);
				}, 150);
			}

			function updateBreathing(timestamp: number) {
				if (!isAnimating) return;
				if (!lastTimestamp) lastTimestamp = timestamp;
				
				const deltaTime = timestamp - lastTimestamp;
				lastTimestamp = timestamp;

				const duration = 30000;
				currentDistance += (length / duration) * deltaTime;

				if (currentDistance >= length) {
					stopAnimation();
					return;
				}

				path.style.strokeDashoffset = (length - currentDistance).toString();

				const currentPoint = path.getPointAtLength(currentDistance);
				const nextPoint = path.getPointAtLength(Math.min(currentDistance + 4, length));
				
				const heightIntensity = (baselineY - currentPoint.y) / (baselineY - peakY);
				const scale = 1 + (Math.max(0, heightIntensity) * 0.15);
				btn?.style.setProperty('transform', `scale(${scale})`);

				const dy = nextPoint.y - currentPoint.y;
				
				// Lógica de estado ultra-refinada
				if (dy < -0.1) {
					setUIState('inhale'); // Subiendo pico
				} else if (dy > 0.1) {
					setUIState('exhale'); // Bajando pico
				} else {
					// En zonas planas
					if (currentDistance < length * 0.15) { 
						// Parte plana inicial previa al primer pico -> Inhalamos
						setUIState('inhale');
					} else {
						// Zonas planas entre picos y final -> Exhalamos (Esperando nueva subida)
						setUIState('exhale');
					}
				}

				rafId = requestAnimationFrame(updateBreathing);
			}

			function stopAnimation() {
				isAnimating = false;
				currentDistance = 0;
				lastTimestamp = 0;
				path.style.strokeDashoffset = '0';
				btn?.style.setProperty('transform', 'scale(1)');
				if (text) {
					text.innerText = 'Inhala y exala.';
					text.style.opacity = '1';
				}
				currentUIState = 'idle';
				isChangingText = false;
				cancelAnimationFrame(rafId);
			}

			btn?.addEventListener('click', () => {
				if (isAnimating) {
					stopAnimation();
				} else {
					isAnimating = true;
					currentDistance = 0;
					lastTimestamp = 0;
					currentUIState = 'inhale'; // Forzamos estado inicial coherente
					if (text) text.innerText = 'Inhala...';
					path.style.strokeDashoffset = length.toString();
					rafId = requestAnimationFrame(updateBreathing);
				}
			});
		</script>
		<script>
			import { Observer } from 'tailwindcss-intersect';
			Observer.start();
    </script>
	</body>
</html>
