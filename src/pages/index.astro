---
import '../styles/global.css';

import { Image } from 'astro:assets';
import imagen1 from '../assets/imagenCarla1.png';
import imagen2 from '../assets/imagenCarla2.png';
import iconSnowflake from '../assets/Snowflake.svg';
import iconSparkle from '../assets/Sparkle.svg';
import iconStar from '../assets/Star.svg';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Carla Perrotta | Psicóloga Clínica</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,100..1000&family=Inter:wght@100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased font-inter text-dark">
		<!-- Aquí irá el desarrollo Mobile First -->
		<header class="bg-primary h-[5.75rem] flex items-center justify-center px-4 top-0 z-50">
			<p class="font-dmsans font-bold text-white text-base md:text-[1.5625rem] tracking-[0.16rem] leading-5.25 uppercase text-center max-w-[17.5rem] md:max-w-none">
				Sanar también es entender tu historia.
			</p>
		</header>
		<main>
			
			<!-- Seccion de Presentacion -->
			<section class="relative bg-secondary overflow-hidden -mt-[0.58rem] pt-7 pb-13 flex flex-col items-center">
				<!-- Nombre de impacto -->
				<h1 class="font-playfair font-normal text-white text-[5.25rem] md:text-[14.75rem] leading-[0.77] text-center z-10 relative px-4">
					Carla<br />Perrotta
				</h1>

				<!-- Contenedor Imagen + Badge (Pegados al texto sin superponerse) -->
				<div class="relative flex flex-col items-center z-20 -mt-12 md:-mt-18">
					<div class="w-[20.511rem] h-[26.209rem] md:w-[38.154rem] md:h-[48.753rem]">
						<Image src={imagen1} alt="Carla Perrotta" loading="eager" class="w-full h-full object-cover"/>
					</div>
					<!-- Badge superpuesto a la base de la imagen -->
					<span class="bg-primary text-white font-dmsans font-bold py-[0.59rem] px-[1.98rem] rounded-full text-[0.99rem] md:text-xl tracking-[0.099rem] md:tracking-[0.125rem] uppercase -mt-8 md:-mt-10 z-30 relative whitespace-nowrap">
						Psicóloga clínica
					</span>
				</div>

				<!-- Info y Especialidades -->
				<div class="mt-2 flex flex-col items-center text-center px-6 z-30">
					<h2 class="font-inter font-bold text-dark text-[1.466875rem] md:text-[1.5625rem] leading-[1.26] mb-5 max-w-[18.4375rem] md:max-w-[35.375rem]">
						Psicoanálisis + terapia <br /> cognitivo-conductual
					</h2>

					<div class="font-inter font-medium text-dark text-xl md:text-[1.5625rem] leading-[1.44] max-w-[20.8125rem] md:max-w-[41.5625rem]">
						<p>Especializada en:</p>
						<p>Ansiedad | Vínculos afectivos |</p>
						<p>Abuso narcisista</p>
						<p>Dependencia emocional | Duelo</p>
					</div>
				</div>
			</section>

			<!-- Seccion de Cita Naranja -->
			<section class="bg-primary pt-16 pb-12 md:py-32 px-6 flex flex-col items-center justify-center text-center text-white">
				<div class="max-w-[19.5rem] md:max-w-[55.75rem]">
					<h2 class="font-playfair text-[1.886rem] md:text-[5.397rem] leading-[0.94] mb-3 md:mb-12 ">
						La <span class="font-bold">terapia</span> no es para personas rotas, <br/>
						<span class="font-bold">es para valientes</span> que quieren entenderse.
					</h2>
					<p class="font-inter text-[1.13rem] md:text-[2.576rem] leading-[1.33] uppercase opacity-90">
						Porque entenderte es el primer paso para dejar de repetir lo que te lastima.
					</p>
				</div>
			</section>

			<!-- Seccion de 3 Beneficios -->
			<section class="bg-secondary-light overflow-hidden flex flex-col md:flex-row items-center justify-center pb-26 md:py-0 md:h-[42.9375rem]">
				<!-- Imagen de Carla -->
				<div class="w-full md:w-1/2 flex justify-center md:justify-end md:pr-12 -mt-5">
					<div class="w-[27.4125rem] h-[41.11875rem] relative">
						<Image src={imagen2} alt="Carla Perrotta" class="w-full h-full object-cover" />
					</div>
				</div>

				<!-- Tarjetas de Beneficios -->
				<div class="-mt-57 md:mt-0 flex flex-col gap-[1.51rem] md:gap-[2.125rem] px-6 md:px-0 md:w-1/2 md:items-start z-10">
					<!-- Beneficio 1 -->
					<div class="bg-primary rounded-[1.29rem] px-[1.25rem] py-2.5 md:p-[1.625rem] flex items-center gap-[1.2rem] md:gap-[1.68rem] max-w-[18.81rem] md:max-w-[34.96rem]">
						<Image src={iconSnowflake} alt="" class="w-8.5 h-8.5 md:w-12 md:h-12 shrink-0" />
						<p class="text-white text-[1.11rem] md:text-[1.56rem] leading-[1.44] font-inter">
							<span class="font-bold">Sanar no es olvidar lo que pasó.</span><br />
							Es dejar de vivir atrapado en ello.
						</p>
					</div>

					<!-- Beneficio 2 -->
					<div class="bg-primary rounded-[1.29rem] px-[1.25rem] py-2.5 md:p-[1.625rem] flex items-center gap-[1.2rem] md:gap-[1.68rem] max-w-[18.81rem] md:max-w-[34.96rem]">
						<Image src={iconSparkle} alt="" class="w-8.5 h-8.5 md:w-12 md:h-12 shrink-0" />
						<p class="text-white text-[1.11rem] md:text-[1.56rem] leading-[1.44] font-inter font-bold">
							Entender lo que sientes cambia la forma en que te relacionas.
						</p>
					</div>

					<!-- Beneficio 3 -->
					<div class="bg-primary rounded-[1.29rem] px-[1.25rem] py-2.5 md:p-[1.625rem] flex items-center gap-[1.2rem] md:gap-[1.68rem] max-w-[18.81rem] md:max-w-[34.96rem]">
						<Image src={iconStar} alt="" class="w-8.5 h-8.5 md:w-12 md:h-12 shrink-0" />
						<p class="text-white text-[1.11rem] md:text-[1.56rem] leading-[1.44] font-inter font-bold">
							No todo lo que duele es debilidad. <span class="font-medium">A veces es historia no comprendida.</span>
						</p>
					</div>
				</div>
			</section>

		</main>
	</body>
</html>
